<% layout("layouts/boilerplate") %>

<div class="container">
  <div class="post-box">

    <form action="/posts" method="POST" class="post-content">
      <label for="username">Username</label>
      <input
        type="text"
        name="username"
        id="username"
        placeholder="@username"
        required
      />

      <label for="content">Content</label>
      <textarea
        name="content"
        id="content"
        rows="5"
        placeholder="What's on your mind?"
        required
      ></textarea>

      <div class="post-actions">
        <button type="submit" class="btn update-btn">Post</button>
        <a href="/posts" class="btn delete-btn">Cancel</a>
      </div>
    </form>
  </div>
</div>
